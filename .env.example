# -----------------------------------------------------------------------------
# Running this locally:
#   1. npm install
#   2. Fill in the values below (see per-variable notes)
#   3. In Authentik, add http://localhost:3000/api/auth/callback/authentik as
#      an allowed Redirect URI on the ktpapp OIDC provider, alongside the
#      production ones — otherwise SSO login will fail locally - (it already is so don't worry)
#   4. npm run dev, then log in with a real Authentik account to reach a portal
#   5. If there is junk in the DB that needs to be cleared out, reach out to Infrastructure.
# -----------------------------------------------------------------------------

# Authentik OIDC (Authentik admin -> Applications -> Providers -> ktpapp)
# Same client ID/secret work locally and in production — it's the same
# registered app, just needs localhost added as a redirect URI (see above).
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_ISSUER=https://auth.ugaktp.com/application/o/ktpapp/

# Auth.js v5 session encryption secret.
# Generate your own for local dev — don't reuse the production value here;
# keep the real production secret only on the server.
# openssl rand -base64 32
AUTH_SECRET=

# Production: AUTH_URL=https://ugaktp.com
# Local:      AUTH_URL=http://localhost:3000
AUTH_URL=https://ugaktp.com

# Required in production (Traefik reverse-proxies the request, so NextAuth
# can't infer the real host on its own). Not needed for plain localhost dev
# — leave it commented out locally.
# AUTH_TRUST_HOST=true

# ktp-api's address.
# Production (LXC 116 -> LXC 119, internal network): API_URL=http://10.0.0.53:4000
# Local: use the public address below.
API_URL=https://api2.ugaktp.com
